# API service configuration
NODE_ENV=development
HOST=0.0.0.0
PORT=3000
LOG_LEVEL=info

# Postgres (matches docker-compose.yml)
DATABASE_URL=postgresql://pinepilot:pinepilot@localhost:5432/pinepilot?schema=public

# Redis (matches docker-compose.yml)
REDIS_URL=redis://localhost:6379

# Auth (A1)
# Google OAuth client ID the extension authenticates with; backend verifies
# Google ID tokens against this audience.
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
# HS256 signing secret for short-lived access tokens (use a long random value).
JWT_ACCESS_SECRET=change-me-to-a-long-random-secret
# Access token lifetime in seconds (default 900 = 15 minutes).
ACCESS_TOKEN_TTL_SECONDS=900
# Refresh token lifetime in days (default 30).
REFRESH_TOKEN_TTL_DAYS=30

# Generation / LLM (G1)
OPENAI_API_KEY=sk-your-openai-api-key
# Model must support strict structured outputs.
OPENAI_MODEL=gpt-4o-2024-08-06
# Retries when model output fails schema/guardrail validation.
LLM_MAX_RETRIES=1
