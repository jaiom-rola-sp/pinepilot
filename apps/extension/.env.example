# Extension build-time public config (inlined by Plasmo at build).
# Only PLASMO_PUBLIC_* values are exposed to the bundle; never put secrets here.

# Backend API base URL the background worker calls.
PLASMO_PUBLIC_API_BASE_URL=http://localhost:3000

# Google OAuth client ID used for chrome.identity sign-in. Must match the
# GOOGLE_CLIENT_ID configured on the backend (token audience).
PLASMO_PUBLIC_GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
